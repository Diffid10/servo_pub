<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="LVvrf[@p4h/3I$3#H6T=" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="}i:f_3[FeD6k1p4tp6sb"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace SmoothServo {" line1="" line2="    //% blockId=smooth_servo_move" line3="    //% block=&quot;servo %pin|from %start to %end in %time ms (smooth)&quot;" line4="    //% weight=100" line5="    export function moveSmooth(pin: AnalogPin, start: number, end: number, time: number): void {" line6="" line7="        let steps = Math.abs(end - start)" line8="        if (steps == 0) return" line9="" line10="        for (let i = 0; i &lt;= steps; i++) {" line11="" line12="            let t = i / steps" line13="            let ease = t * t * (3 - 2 * t) // smoothstep" line14="" line15="            let angle = start + (end - start) * ease" line16="" line17="            pins.servoWritePin(pin, angle)" line18="            basic.pause(time / steps)" line19="        }" line20="    }" line21="}" numlines="22"></mutation><next><block type="smooth_servo_move" id="r9we]6afQaQf9aTSnKn="><field name="pin">AnalogPin.P0</field><value name="start"><shadow type="math_number" id="|Bnu_]J;C/er,$n(H#yI"><field name="NUM">0</field></shadow></value><value name="end"><shadow type="math_number" id="#}iGsUOW#8,xyD,^u)r."><field name="NUM">0</field></shadow></value><value name="time"><shadow type="math_number" id="8|:q-e)7l!Ow`0Mdy(I,"><field name="NUM">0</field></shadow></value></block></next></block></statement></block></xml>