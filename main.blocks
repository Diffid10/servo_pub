<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id=",HxZEa!xs!eAvg!gP~67" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="}?m[0ANM{tr157)7{}CA"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace SmoothServo {" line1="" line2="    //% block=&quot;servo pin %pin|from %start to %end in %time ms (smooth)&quot;" line3="    export function moveSmooth(pin: AnalogPin, start: number, end: number, time: number): void {" line4="" line5="        let steps = Math.abs(end - start)" line6="        if (steps == 0) return" line7="" line8="        let direction = start &lt; end ? 1 : -1" line9="" line10="        for (let i = 0; i &lt;= steps; i++) {" line11="" line12="            //  easing function (smooth motion)" line13="            let t = i / steps" line14="            let ease = t * t * (3 - 2 * t)   // smoothstep" line15="" line16="            let angle = start + (end - start) * ease" line17="" line18="            pins.servoWritePin(pin, angle)" line19="            basic.pause(time / steps)" line20="        }" line21="    }" line22="}" numlines="23"></mutation></block></statement></block></xml>