<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="ImfA$n4Q;5WK{~+];[7O" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="ZZUI2B?6W{laSU7vC:wO"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Servo_For_Chun {" line1="" line2="    let currentAngle = 90" line3="" line4="    //% blockId=servo_set_angle" line5="    //% block=&quot;servo %pin set angle %angle&quot;" line6="    //% weight=100" line7="    export function setAngle(pin: AnalogPin, angle: number): void {" line8="        if (angle &gt; 180) angle = 180" line9="        if (angle &lt; 0) angle = 0" line10="" line11="        pins.servoWritePin(pin, angle)" line12="        currentAngle = angle" line13="    }" line14="" line15="    //% blockId=servo_move_relative" line16="    //% block=&quot;servo %pin move %direction by %angle degrees&quot;" line17="    //% weight=90" line18="    export function moveRelative(pin: AnalogPin, direction: Direction, angle: number): void {" line19="        let target = currentAngle + direction * angle" line20="" line21="        if (target &gt; 180) target = 180" line22="        if (target &lt; 0) target = 0" line23="" line24="        pins.servoWritePin(pin, target)" line25="        currentAngle = target" line26="    }" line27="" line28="    //% blockId=servo_move_smooth" line29="    //% block=&quot;servo %pin from %start to %end in %time ms (smooth)&quot;" line30="    //% weight=80" line31="    export function moveSmooth(pin: AnalogPin, start: number, end: number, time: number): void {" line32="" line33="        let steps = Math.abs(end - start)" line34="        if (steps == 0) return" line35="" line36="        for (let i = 0; i &lt;= steps; i++) {" line37="" line38="            let t = i / steps" line39="            let ease = t * t * (3 - 2 * t)" line40="" line41="            let angle = start + (end - start) * ease" line42="" line43="            pins.servoWritePin(pin, angle)" line44="            basic.pause(time / steps)" line45="        }" line46="" line47="        currentAngle = end" line48="    }" line49="}" numlines="50"></mutation></block></statement></block></xml>