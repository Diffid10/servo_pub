<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="w_Jh}0*u_TbqtpwzP$X4" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="+,yILG/L66J~Z}2uk`cy"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Servo_For_Chun {" line1="" line2="    let currentAngle = 90" line3="" line4="    //% blockId=servo_set_angle" line5="    //% block=&quot;servo %pin set angle %angle&quot;" line6="    //% weight=100" line7="    export function setAngle(pin: AnalogPin, angle: number): void {" line8="        if (angle &gt; 180) angle = 180" line9="        if (angle &lt; 0) angle = 0" line10="" line11="        pins.servoWritePin(pin, angle)" line12="        currentAngle = angle" line13="    }" line14="" line15="    //% blockId=servo_move_relative" line16="    //% block=&quot;servo %pin move %direction by %angle degrees&quot;" line17="    //% weight=90" line18="    export function moveRelative(pin: AnalogPin, direction: Direction, angle: number): void {" line19="        let target = currentAngle + direction * angle" line20="" line21="        if (target &gt; 180) target = 180" line22="        if (target &lt; 0) target = 0" line23="" line24="        pins.servoWritePin(pin, target)" line25="        currentAngle = target" line26="    }" line27="" line28="    //% blockId=smooth_servo_move" line29="    //% block=&quot;servo %pin|from %start to %end in %time ms (smooth)&quot;" line30="    export function moveSmooth(pin: AnalogPin, start: number, end: number, time: number): void {" line31="" line32="        let steps = Math.abs(end - start)" line33="        if (steps == 0) return" line34="" line35="        let direction = start &lt; end ? 1 : -1" line36="" line37="        for (let i = 0; i &lt;= steps; i++) {" line38="" line39="            let t = i / steps" line40="            let ease = t * t * (3 - 2 * t)" line41="" line42="            let angle = start + (end - start) * ease" line43="" line44="            pins.servoWritePin(pin, angle)" line45="            basic.pause(time / steps)" line46="        }" line47="    }" line48="    //% blockId=servo_tune" line49="    //% block=&quot;set servo %pin by buttons (A=+, B=-, A+B=ok)&quot;" line50="    //% weight=110" line51="    export function tuneServo(pin: AnalogPin): number {" line52="" line53="        let angle2 = 90" line54="        let done = false" line55="" line56="        pins.servoWritePin(pin, angle2)" line57="" line58="        input.onButtonPressed(Button.A, function () {" line59="            if (!done) {" line60="                angle2 += 1" line61="                if (angle2 &gt; 180) angle2 = 180" line62="                pins.servoWritePin(pin, angle2)" line63="                basic.showNumber(angle2)" line64="            }" line65="        })" line66="" line67="        input.onButtonPressed(Button.B, function () {" line68="            if (!done) {" line69="                angle2 -= 1" line70="                if (angle2 &lt; 0) angle2 = 0" line71="                pins.servoWritePin(pin, angle2)" line72="                basic.showNumber(angle2)" line73="            }" line74="        })" line75="" line76="        input.onButtonPressed(Button.AB, function () {" line77="            done = true" line78="            basic.clearScreen()" line79="        })" line80="" line81="        while (!done) {" line82="            basic.pause(50)" line83="        }" line84="" line85="        return angle2" line86="    }" line87="}" numlines="88"></mutation></block></statement></block></xml>